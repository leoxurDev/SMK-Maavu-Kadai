# Django Settings
SECRET_KEY=django-insecure-replace-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# Leave empty to default to SQLite (useful for running directly on your laptop)
DB_ENGINE=mysql
DB_NAME=smk_flour_shop
DB_USER=smk_user
DB_PASSWORD=smk_password
DB_HOST=127.0.0.1
DB_PORT=3306

# Redis and Celery Configuration
# Leave empty to default to dummy/in-memory queues (useful for running directly on your laptop)
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# Razorpay settings (replace with actual keys)
RAZORPAY_KEY_ID=rzp_test_example
RAZORPAY_KEY_SECRET=example_secret

# SMS OTP Provider Settings
# Options: none (dev sandbox console), twilio, fast2sms
SMS_PROVIDER=none
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_from_phone_number
FAST2SMS_API_KEY=your_fast2sms_api_key

# Custom Business Name in SMS OTP Message
SMS_BUSINESS_NAME=Manikandan Maavu Kadai
